
import pandas as pd
import requests
import time

# ========================
# CONFIG
# ========================
API_KEY = "YOUR_NEW_API_KEY"
API_URL = "https://whatcms.org/APIEndpoint"
INPUT_FILE = "WHATCMS_INPUT.xlsx"
OUTPUT_FILE = "WHATCMS_ENRICHED_OUTPUT.xlsx"

# ========================
# LOAD INPUT FILE
# ========================
df = pd.read_excel(INPUT_FILE)

# Clean URLs
df["url"] = (
    df["url"]
    .astype(str)
    .str.lower()
    .str.replace("http://", "", regex=False)
    .str.replace("https://", "", regex=False)
    .str.strip()
)

# Remove duplicates
df = df.drop_duplicates(subset=["url"])

# ========================
# CREATE REQUIRED COLUMNS
# ========================
required_columns = [
    "url",
    "whatcms_link",
    "Blog_CMS",
    "E-commerce_CMS",
    "Programming_Language",
    "Database",
    "CDN",
    "Web_Server",
    "Landing_Page_Builder_CMS",
    "Operating_System",
    "Web_Framework",
    "whatcms_response"
]

for col in required_columns:
    if col not in df.columns:
        df[col] = ""

# ========================
# WHATCMS API FUNCTION
# ========================
def call_whatcms(domain):
    try:
        params = {
            "key": API_KEY,
            "url": domain
        }

        response = requests.get(API_URL, params=params)
        data = response.json()

        result = {
            "whatcms_link": f"https://whatcms.org/?s={domain}",
            "Blog_CMS": "",
            "E-commerce_CMS": "",
            "Programming_Language": "",
            "Database": "",
            "CDN": "",
            "Web_Server": "",
            "Landing_Page_Builder_CMS": "",
            "Operating_System": "",
            "Web_Framework": "",
            "whatcms_response": "No Data Found"
        }

        if data.get("result") and "technologies" in data:
            result["whatcms_response"] = "Success"

            for tech in data["technologies"]:
                category = tech.get("category", "")
                name = tech.get("name", "")

                if "Blog" in category:
                    result["Blog_CMS"] = name
                elif "Ecommerce" in category:
                    result["E-commerce_CMS"] = name
                elif "Programming" in category:
                    result["Programming_Language"] = name
                elif "Database" in category:
                    result["Database"] = name
                elif "CDN" in category:
                    result["CDN"] = name
                elif "Web Server" in category:
                    result["Web_Server"] = name
                elif "Landing" in category:
                    result["Landing_Page_Builder_CMS"] = name
                elif "Operating System" in category:
                    result["Operating_System"] = name
                elif "Web Framework" in category:
                    result["Web_Framework"] = name

        return result

    except Exception as e:
        return {
            "whatcms_link": "",
            "Blog_CMS": "",
            "E-commerce_CMS": "",
            "Programming_Language": "",
            "Database": "",
            "CDN": "",
            "Web_Server": "",
            "Landing_Page_Builder_CMS": "",
            "Operating_System": "",
            "Web_Framework": "",
            "whatcms_response": "Error"
        }

# ========================
# LOOP THROUGH 50 URLS
# ========================
for index, row in df.iterrows():
    domain = row["url"]
    print(f"Processing: {domain}")

    result = call_whatcms(domain)

    for key, value in result.items():
        df.at[index, key] = value

    time.sleep(1)  # Prevent hitting API limit

# ========================
# SAVE OUTPUT
# ========================
df = df[required_columns]
df.to_excel(OUTPUT_FILE, index=False)

print("✅ DONE! File saved as WHATCMS_ENRICHED_OUTPUT.xlsx")
